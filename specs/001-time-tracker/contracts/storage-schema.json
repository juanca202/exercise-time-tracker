{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TimeTrackerPersistedState",
  "description": "localStorage payload at key time-tracker:v1",
  "type": "object",
  "required": ["version", "state"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "state": {
      "type": "object",
      "required": [
        "projects",
        "tasks",
        "timeEntries",
        "activeTimer",
        "selectedPeriod"
      ],
      "properties": {
        "projects": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "name", "createdAt"],
            "properties": {
              "id": { "type": "string", "format": "uuid" },
              "name": { "type": "string", "minLength": 1 },
              "description": { "type": "string" },
              "createdAt": { "type": "string", "format": "date-time" }
            }
          }
        },
        "tasks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "projectId", "name", "createdAt"],
            "properties": {
              "id": { "type": "string", "format": "uuid" },
              "projectId": { "type": "string", "format": "uuid" },
              "name": { "type": "string", "minLength": 1 },
              "createdAt": { "type": "string", "format": "date-time" }
            }
          }
        },
        "timeEntries": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "taskId",
              "date",
              "startedAt",
              "endedAt",
              "durationMs",
              "source",
              "createdAt"
            ],
            "properties": {
              "id": { "type": "string", "format": "uuid" },
              "taskId": { "type": "string", "format": "uuid" },
              "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
              "startedAt": { "type": "string", "format": "date-time" },
              "endedAt": { "type": "string", "format": "date-time" },
              "durationMs": { "type": "integer", "minimum": 1 },
              "source": { "type": "string", "enum": ["timer", "manual"] },
              "createdAt": { "type": "string", "format": "date-time" }
            }
          }
        },
        "activeTimer": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "required": ["taskId", "startedAt"],
              "properties": {
                "taskId": { "type": "string", "format": "uuid" },
                "startedAt": { "type": "string", "format": "date-time" }
              }
            }
          ]
        },
        "selectedPeriod": {
          "type": "object",
          "required": ["year", "month"],
          "properties": {
            "year": { "type": "integer", "minimum": 2000 },
            "month": { "type": "integer", "minimum": 1, "maximum": 12 }
          }
        }
      }
    }
  }
}
